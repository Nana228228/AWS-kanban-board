#!/bin/sh
# ----------------------------------------------------------------------------
# Licensed to the Apache Software Foundation (ASF) under one
# or more contributor license agreements.
# ----------------------------------------------------------------------------

# Determine the project base directory
if [ -z "$MAVEN_PROJECTBASEDIR" ]; then
  MAVEN_PROJECTBASEDIR=$(cd "$(dirname "$0")" && pwd)
  export MAVEN_PROJECTBASEDIR
fi

MAVEN_WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"

if [ -r "$MAVEN_WRAPPER_JAR" ]; then
  if [ -n "$JAVA_HOME" ]; then
    JAVACMD="$JAVA_HOME/bin/java"
  else
    JAVACMD="$(which java)"
  fi
  if [ ! -x "$JAVACMD" ]; then
    echo "Error: JAVA_HOME is not defined correctly or java is not in PATH." >&2
    exit 1
  fi
  exec "$JAVACMD" \
    $MAVEN_OPTS \
    -classpath "$MAVEN_WRAPPER_JAR" \
    org.apache.maven.wrapper.MavenWrapperMain "$@"
else
  echo "Error: Maven wrapper JAR not found at $MAVEN_WRAPPER_JAR" >&2
  echo "Run: mvn wrapper:wrapper to generate it" >&2
  exit 1
fi
